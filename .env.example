# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string (Neon in production; for local dev you can run
# `pnpm prisma dev` to start a local Postgres instance and use the
# connection string it prints).
DATABASE_URL="postgresql://user:password@localhost:5432/milesos?schema=public"

# Google OAuth (Auth.js) — used for both login and (later) the Gmail
# read-only consent flow. Create a Web application OAuth 2.0 credential in
# the Google Cloud Console, with authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# The single allow-listed Google account permitted to log in. Not yet
# enforced (M1A allows any Google account) — will gate sign-in before
# deployment.
ALLOWED_USER_EMAIL=""

# Auth.js secret (generate with `npx auth secret` or `openssl rand -base64 32`).
AUTH_SECRET=""

# Anthropic API key, used for email/transaction extraction.
ANTHROPIC_API_KEY=""
