// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id String @id @default(cuid())

  // Gmail metadata
  gmailMessageId  String   @unique
  gmailThreadId   String
  gmailReceivedAt DateTime

  // Normalized financial transaction data only -- mirrors Transaction /
  // TransactionSchema in src/lib/transaction.ts, minus confidence/reasoning
  // (AI debugging metadata, deliberately not persisted here)
  bank            String
  merchant        String?
  amount          Decimal
  currency        String
  transactionKind String
  direction       String
  cardLastFour    String?
  transactionDate DateTime @db.Date

  createdAt DateTime @default(now())
}

model Account {
  id   String @id @default(cuid())
  name String
  // "cash" | "cash_equivalent" | "investment" | "credit_card" -- validated
  // at the app layer (zod), not a Prisma enum. Same reasoning already
  // applied to Transaction.bank/transactionKind/direction: a DB enum would
  // need a migration every time a type is added (CPF, property, liability
  // are named as future needs) -- a plain string with app-level validation
  // doesn't.
  type String

  currentBalance   Decimal
  currency         String
  // Tracks specifically when the balance was last changed, not a generic
  // row-level updatedAt -- set explicitly in the update path, not Prisma's
  // @updatedAt (which would fire on any field edit, e.g. renaming an
  // account, and misleadingly look like a balance refresh).
  balanceUpdatedAt DateTime @default(now())

  // The entire "data-driven inclusion" mechanism: whether an account
  // counts toward each dashboard aggregate is a data decision made once
  // per account, never a code decision.
  includedInAvailableCash Boolean @default(false)
  includedInNetWorth      Boolean @default(false)

  // Lets an account be hidden (e.g. closed) later without deleting its
  // row or breaking any future Transaction linkage.
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}
