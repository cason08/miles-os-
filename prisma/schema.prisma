// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id String @id @default(cuid())

  // Gmail metadata -- present only when source == "gmail", null for
  // manually entered transactions. @unique still works correctly with
  // nulls (Postgres allows multiple NULLs in a unique column).
  gmailMessageId  String?   @unique
  gmailThreadId   String?
  gmailReceivedAt DateTime?

  // "gmail" | "manual" -- plain string, same reasoning as bank/
  // transactionKind/direction. Existing rows default to "gmail" via this
  // migration (they're all Gmail-imported today).
  source String @default("gmail")

  // Normalized financial transaction data only -- mirrors Transaction /
  // TransactionSchema in src/lib/transaction.ts, minus confidence/reasoning
  // (AI debugging metadata, deliberately not persisted here)
  // Null for manual entries (no sender email to extract a bank name from).
  // Display prefers the linked Account's name (below) when present,
  // falling back to this raw string otherwise.
  bank            String?
  merchant        String?
  amount          Decimal
  currency        String
  transactionKind String
  direction       String
  cardLastFour    String?
  transactionDate DateTime @db.Date

  createdAt DateTime @default(now())

  categoryId String?
  // SetNull, not the Restrict default -- deleting a category must never
  // delete or block deletion of transaction history; it just falls back
  // to uncategorized.
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  // "manual" | "rule" (-> "ai" once AI categorisation ships). Plain
  // string, same reasoning as bank/transactionKind/direction. Set
  // whenever categoryId is set, null otherwise -- exists so a future rule
  // re-run (or AI categorisation) never silently overwrites a
  // categorisation the user chose by hand.
  categorySource String?

  accountId String?
  // SetNull -- deleting an account must never delete or block deletion of
  // transaction history (same reasoning as the Category relation above).
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model Account {
  id   String @id @default(cuid())
  name String
  // "cash" | "cash_equivalent" | "investment" | "credit_card" -- validated
  // at the app layer (zod), not a Prisma enum. Same reasoning already
  // applied to Transaction.bank/transactionKind/direction: a DB enum would
  // need a migration every time a type is added (CPF, property, liability
  // are named as future needs) -- a plain string with app-level validation
  // doesn't.
  type String

  currentBalance   Decimal
  currency         String
  // Tracks specifically when the balance was last changed, not a generic
  // row-level updatedAt -- set explicitly in the update path, not Prisma's
  // @updatedAt (which would fire on any field edit, e.g. renaming an
  // account, and misleadingly look like a balance refresh).
  //
  // Doubles today as the reconciliation baseline timestamp: currentBalance
  // is the confirmed-accurate figure as of this moment, and transactions
  // dated on/after it adjust a *displayed* balance on top (see
  // getDisplayedBalance() in src/lib/accounts.ts, the one place that reads
  // this field for that purpose). Treated as an implementation detail, not
  // the long-term model -- if Account ever gains other editable metadata
  // that shouldn't reset the baseline, split this into a dedicated
  // `baselineAt` field. That's a one-place change: only
  // getDisplayedBalance() (via its getBaselineTimestamp() helper) and this
  // update path would need to point at the new field instead.
  balanceUpdatedAt DateTime @default(now())

  // The entire "data-driven inclusion" mechanism: whether an account
  // counts toward each dashboard aggregate is a data decision made once
  // per account, never a code decision.
  includedInAvailableCash Boolean @default(false)
  includedInNetWorth      Boolean @default(false)

  // Lets an account be hidden (e.g. closed) later without deleting its
  // row or breaking any future Transaction linkage.
  isActive Boolean @default(true)

  // Matching signal for MonthlyCommitment (and future Card Optimiser work)
  // -- only meaningful for credit_card-type accounts, null otherwise.
  cardLastFour String?

  createdAt DateTime @default(now())

  monthlyCommitments MonthlyCommitment[]
  transactions       Transaction[]
}

model MonthlyCommitment {
  id   String @id @default(cuid())
  name String
  // "insurance" | "loan" | "installment" | "utility" | "mobile_plan" |
  // "streaming" | "software" | "mortgage" -- plain string, app-validated
  // (zod), not a Prisma enum. Same reasoning as Account.type /
  // Transaction.bank: a new category is a one-line addition, not a
  // migration.
  type String

  expectedAmount     Decimal
  currency           String
  expectedDayOfMonth Int
  dayTolerance       Int @default(3)

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())
}

// General-purpose app-level singleton row (fixed id) -- not sync-specific.
// Today it only holds sync-related fields; future app-level metadata
// (e.g. a balance-baseline timestamp, onboarding state) can live here too
// without a new table.
model AppState {
  id String @id @default("singleton")

  // Purely product/UX metadata ("last time the user successfully ran
  // Sync") -- never read by the importer itself.
  lastSyncedAt DateTime?

  // Internal engine checkpoint: the newest gmailReceivedAt among ALL
  // processed messages (imported, ignored, or failed-past-fetch), not just
  // successfully imported ones. Ignored/failed emails never get a
  // Transaction row, so without this, Daily Sync would keep re-fetching
  // and re-sending them to Claude on every run until an unrelated real
  // transaction happened to move the checkpoint forward.
  lastProcessedGmailReceivedAt DateTime?
}

model Category {
  id   String @id @default(cuid())
  name String
  // Implicitly monthly for v1 -- a future budgetPeriod column (defaulting
  // existing rows to "monthly") would generalize cadence later without a
  // redesign of this one.
  budget   Decimal?
  currency String
  // Hex string (e.g. "#4F46E5"), not a fixed token palette -- stays
  // flexible as the category list grows; read once here and reused
  // consistently across dashboard cards, budget cards, and charts instead
  // of each component guessing its own color.
  color String?
  // Archive, not delete -- a category with historical transactions
  // attached shouldn't disappear from past data when retired.
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  transactions Transaction[]
  rules        MerchantRule[]
}

model MerchantRule {
  id String @id @default(cuid())

  categoryId String
  // Cascade -- a rule is meaningless without its category, so it goes
  // away with it rather than becoming an orphan or blocking deletion.
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // v1: one matching signal, case-insensitive merchant substring. Future
  // rule types (MCC, keywords, bank-specific) are new columns or a new
  // rule-type table -- not a redesign of this one.
  merchantPattern String

  createdAt DateTime @default(now())
}
